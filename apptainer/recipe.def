
Bootstrap: docker
From: astral/uv:python3.13-bookworm-slim


%environment
	# EnergyPlus variable names
	export EPLUS_VERSION_SHORT="22-2-0"
	export EPLUS_DIR="/usr/local/EnergyPlus-${EPLUS_VERSION_SHORT}"

	#  Prevent runtime write attempts
	export UV_NO_SYNC=1

  # project paths
  export NVFLOW="/nvflow"
  export VIRTUAL_ENV="/nvflow/.venv"
  export PATH="/nvflow/.venv/bin:$PATH"


%post 

	######### ------ INSTALL ENERGYPLUS -----------
	EPLUS_VER="22.2.0"
        EPLUS_HASH="c249759bad"
        EPLUS_INSTALLER="EnergyPlus-${EPLUS_VER}-${EPLUS_HASH}-Linux-Ubuntu20.04-x86_64.sh"
	RELEASE_LOC="https://github.com/NatLabRockies/EnergyPlus/releases/download/v${EPLUS_VER}/${EPLUS_INSTALLER}"

	echo $RELEASE_LOC

  # Install the tools needed to support Python and git, which the uv docker
  # image does not ship with 
	apt-get update && apt-get install -y wget git python3-tk libtk8.6 libgomp1

	# Download using the variable
	wget $RELEASE_LOC

	# Run the installer using the variable
	chmod +x ${EPLUS_INSTALLER}
        printf "y\n\n" | ./${EPLUS_INSTALLER}

	# Cleanup using the variable
	rm ${EPLUS_INSTALLER}



  
  ## Baked In Paths ---------------
  # main project folder
  mkdir /nvflow

  # writable folder where action happens (where snakemake can store results)
  mkdir /nvflow/run
  mkdir /nvflow/run/intermed
  mkdir /nvflow/run/shared

  mkdir /nvflow/test
  mkdir /nvflow/test/intermed
  mkdir /nvflow/test/shared

  # connections to samples
  mkdir /nvflow/samples
  mkdir /nvflow/samples/data
  mkdir /nvflow/samples/test
